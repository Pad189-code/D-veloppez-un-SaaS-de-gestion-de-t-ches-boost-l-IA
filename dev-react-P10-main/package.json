{
  "name": "oc-p10",
  "version": "1.0.0",
  "private": true,
  "description": "API REST avec authentification utilisateur - Node.js + Express + TypeScript + Prisma",
  "workspaces": [
    "abricot-frontend"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon",
    "dev:web": "npm run dev -w abricot-frontend",
    "lint:web": "npm run lint -w abricot-frontend",
    "build:web": "npm run build -w abricot-frontend",
    "check:web": "npm run check -w abricot-frontend",
    "format": "prettier --write \"src/**/*.ts\"",
    "postinstall": "node scripts/postinstall-prisma.cjs",
    "db:generate": "node scripts/prisma-generate-clean.cjs",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio --hostname 127.0.0.1 --port 5556",
    "seed": "ts-node --transpile-only scripts/seed.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "prisma",
    "jwt",
    "authentication"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@llamaindex/mistral": "^0.1.22",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "llamaindex": "^0.12.1",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.1",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
